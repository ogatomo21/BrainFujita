{
  "name": "brainfujita-extension",
  "displayName": "BrainFujita Extension",
  "description": "A Brainfuck-compatible language inspired by Kotone Fujita.",
  "publisher": "ogatomo21",
  "repository": {
    "type": "git",
    "url": "https://github.com/ogatomo21/BrainFujita.git"
  },
  "version": "0.0.1",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "brainfujita",
        "aliases": [
          "BrainFujita",
          "brainfujita"
        ],
        "extensions": [
          ".kf"
        ],
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "brainfujita",
        "scopeName": "source.kf",
        "path": "./syntaxes/brainfujita.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "mocha": "^11.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
